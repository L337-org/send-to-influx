#!/bin/sh
# preinst for send-to-influx.deb
set -e

# Only "upgrade" (and "install" over a still-configured leftover) matter here;
# a genuinely fresh install has nothing to clean up.
case "$1" in
    upgrade|install) ;;
    *) exit 0 ;;
esac

# dpkg-reconfigure ALSO runs preinst, as "upgrade <version>" - indistinguishable
# from a real upgrade by its arguments alone - but with NO unpack following it, so
# anything removed here on that path is gone permanently and breaks the install.
# dpkg-reconfigure exports DEBCONF_RECONFIGURE=1 (the same flag postinst uses to
# tell the two apart), which is the only reliable discriminator; verified to be
# visible here. Bail out before touching anything.
if [ "${DEBCONF_RECONFIGURE:-}" = "1" ]; then
    exit 0
fi

# Remove the bundled virtualenv, so the unpack that follows lays down a pristine
# one.
#
# The venv is entirely package-owned and recreated by every install: no
# configuration (that is /etc/send-to-influx), no credentials (the credstore), and
# nothing user-editable lives in it. Replacing it wholesale rather than letting dpkg
# merge over it removes a whole class of failure at once:
#
#  - Stale modules from a previous version being imported in preference to the new
#    ones. This bit in the field: a 4.4 install logged its 4.4 version banner while
#    running pre-4.3 library code, so it failed with "unexpected keyword argument
#    'use_buffer'" and "Source nuki not found" - the entry point was new, the
#    package behind it was old.
#  - lib/python<major.minor>/ directories left over from a package built against a
#    different interpreter, which dpkg cannot always replace with the symlinks the
#    current layout uses (it will not swap a non-empty directory for a symlink), and
#    which then shadow the real site-packages directory.
#  - Runtime-generated __pycache__ files, which dpkg does not own and will not clean
#    up, keeping those directories alive.
#
# Bytecode and orphaned modules are always safe to delete: everything is
# regenerated by the unpack, and postinst restarts the service afterwards.
rm -rf /opt/send-to-influx/venv

exit 0
